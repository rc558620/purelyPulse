# API
VITE_API_BASE_URL=/api
VITE_API_TIMEOUT=15000

# Auth
VITE_LOGIN_API_PATH=/auth/login
VITE_AUTH_PROFILE_API_PATH=/auth/me

# Home
VITE_HOME_OVERVIEW_API_PATH=/pulse/dashboard/home

# Partner
VITE_PARTNER_REVIEW_API_PATH=/pulse/growth/admin/partner-applications
VITE_PARTNER_REVIEW_APPROVE_API_PATH=/pulse/growth/admin/partner-applications/{id}/approve
VITE_PARTNER_REVIEW_REJECT_API_PATH=/pulse/growth/admin/partner-applications/{id}/reject
VITE_PARTNER_PAYOUT_API_PATH=/pulse/growth/admin/payouts
VITE_PARTNER_PAYOUT_APPROVE_API_PATH=/pulse/growth/admin/payouts/{id}/approve
VITE_PARTNER_PAYOUT_REJECT_API_PATH=/pulse/growth/admin/payouts/{id}/reject
VITE_PARTNER_BEANS_API_PATH=/pulse/membership/beans/logs
VITE_ADJUST_PARTNER_BEANS_API_PATH=/pulse/membership/admin/members/{id}/beans/adjust

# Revenue & promotion
VITE_REVENUE_DETAIL_API_PATH=/revenue-detail
VITE_PROMOTION_DETAIL_API_PATH=/pulse/growth/admin/promo-detail

# Members
VITE_MEMBER_POINTS_API_PATH=/pulse/membership/points/logs
VITE_ADJUST_MEMBER_POINTS_API_PATH=/pulse/membership/admin/members/{id}/points/adjust
VITE_MEMBER_LIST_API_PATH=/pulse/membership/admin/members
VITE_MEMBER_DETAIL_API_PATH=/pulse/membership/admin/members/{id}
VITE_SET_MEMBERSHIP_API_PATH=/pulse/membership/admin/members/{id}/membership
VITE_MEMBER_BAN_API_PATH=/pulse/membership/admin/members/{id}/ban
VITE_MEMBER_UNBAN_API_PATH=/pulse/membership/admin/members/{id}/unban
